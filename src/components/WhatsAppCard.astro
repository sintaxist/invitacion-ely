---
interface Props {
  phoneNumber: string;
  message: string;
}

const { phoneNumber, message } = Astro.props;
const waUrl = `https://wa.me/${phoneNumber}?text=${encodeURIComponent(message)}`;
---

<div class="card-perspective-wrapper relative w-full max-w-140 mx-auto px-5 xs:px-0">
  <a
    href={waUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="wa-card block relative z-10 w-full rounded-3xl overflow-hidden cursor-pointer"
  >
    <div class="absolute inset-0 bg-linear-to-br from-[#1a1a1a] to-[#0a0a0a] z-0"></div>
    
    <div class="spotlight absolute inset-0 opacity-0 transition-opacity duration-300 z-10 pointer-events-none" 
         style="background: radial-gradient(circle 300px at 50% 50%, rgba(201, 144, 64, 0.15), transparent 80%); mix-blend-mode: screen;">
    </div>

    <div class="absolute inset-0 border border-gold/30 rounded-3xl z-10 pointer-events-none"></div>
    <div class="absolute inset-0 border-t border-l border-white/10 rounded-3xl z-10 pointer-events-none"></div>

    <div
      class="wa-content relative z-20 h-full p-10 sm:p-14 flex flex-col items-center justify-center text-center gap-8"
    >
      
      <svg
        class="pop-element w-12 sm:w-15 h-12 sm:h-15 text-white drop-shadow-[0_0_10px_rgba(201,144,64,0.5)] mb-5"
        fill="currentColor"
        viewBox="0 0 24 24"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"
        ></path>
      </svg>

      <h3 class="pop-element font-serif text-rose-35 sm:text-rose-45 text-white leading-[1.1] tracking-wide uppercase">
        Confirmar<br />
        <span class="text-gold font-light text-[1.1em]">asistencia</span>
      </h3>
      
      <p class="pop-element max-w-sm font-sans font-light text-mont-15 sm:text-mont-18 text-white/70 leading-relaxed">
        Envía un mensaje directo a la anfitriona para asegurar tu lugar en la mesa.
      </p>

      <div class="pop-element mt-2 inline-flex items-center gap-2 font-sans font-medium text-mont-12 text-gold tracking-widest uppercase border-b border-gold pb-1 transition-colors">
        <span>Confirmar asistencia</span>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
      </div>
    </div>
  </a>
</div>

<style>
  .card-perspective-wrapper {
    perspective: 1000px;
  }
  .wa-card {
    transform-style: preserve-3d;
    will-change: transform;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.7);
    transition: box-shadow 0.5s ease;
  }
  .wa-card:hover {
    box-shadow: 0 35px 60px -15px rgba(201, 144, 64, 0.2);
  }
  .wa-card:hover .spotlight {
    opacity: 1;
  }
  .wa-content {
    transform-style: preserve-3d;
  }
  .pop-element {
    transform: translateZ(60px); 
  }
</style>

<script>
  import { gsap } from "gsap";

  const wrapper = document.querySelector(".card-perspective-wrapper") as HTMLElement;
  const card = wrapper.querySelector(".wa-card") as HTMLElement;
  const spotlight = wrapper.querySelector(".spotlight") as HTMLElement;
  const contentElements = wrapper.querySelectorAll(".pop-element");

  const rotX = gsap.quickTo(card, "rotationX", { ease: "power2.out", duration: 0.3 });
  const rotY = gsap.quickTo(card, "rotationY", { ease: "power2.out", duration: 0.3 });

  wrapper.addEventListener("pointermove", (e) => {
    if (window.innerWidth < 1024) return;
    
    const { left, top, width, height } = card.getBoundingClientRect();
    
    const centerX = left + width / 2;
    const centerY = top + height / 2;
    
    const mouseX = (e.clientX - centerX) / (width / 2);
    const mouseY = (e.clientY - centerY) / (height / 2);

    const spotX = e.clientX - left;
    const spotY = e.clientY - top;
    spotlight.style.background = `radial-gradient(circle 400px at ${spotX}px ${spotY}px, rgba(201, 144, 64, 0.25), transparent 80%)`;

    rotX(-mouseY * 15);
    rotY(mouseX * 15);

    gsap.to(contentElements, {
      x: mouseX * 25,
      y: mouseY * 25,
      ease: "power2.out",
      duration: 0.3,
    });
  });

  wrapper.addEventListener("pointerleave", () => {
    rotX(0);
    rotY(0);
    gsap.to(contentElements, { x: 0, y: 0, ease: "power2.out", duration: 0.5 });
  });
</script>
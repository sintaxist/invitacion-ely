---
interface Props {
  title: string;
  date?: string;
  time?: string;
  locationName?: string;
  locationAddress?: string;
  mapLink?: string;
  dressCodeText?: string[];

  imageSrc?: string;
  imageAlt?: string;
  spotifyLink?: string;
  youtubeLink?: string;
  description?: string;
}

const {
  title,
  date,
  time,
  locationName,
  locationAddress,
  mapLink,
  dressCodeText,
  imageSrc,
  imageAlt,
  spotifyLink,
  youtubeLink,
  description,
} = Astro.props;
---

<div
  class="card-anim opacity-0 snap-start shrink-0 w-[70vw] sm:w-full last:mr-10 xs:last:mr-20 bg-white/5 backdrop-blur-xl border border-white/10 border-t-white/20 border-l-white/20 shadow-[0_8px_32px_0_rgba(0,0,0,0.5)] rounded-[30px] p-6 xs:p-8 lg:p-10 flex flex-col transform-gpu"
  style="will-change: transform, opacity; backface-visibility: hidden;"
>
  {
    imageSrc && (
      <img
        src={imageSrc}
        alt={imageAlt || title}
        loading="lazy"
        decoding="async"
        class="w-full h-40 object-cover rounded-2xl mb-6 transform-gpu"
        style="backface-visibility: hidden; transform: translateZ(0);"
      />
    )
  }

  <h3 class="font-serif text-rose-30 text-white mb-8 leading-[1.2]">
    {title}
  </h3>

  {
    date && time && locationName && (
      <ul class="space-y-6 flex-1 mb-10">
        <!-- AJUSTE 2: gap-3 en móviles, gap-4 en xs -->
        <li class="flex items-start gap-3 xs:gap-4">
          <!-- AJUSTE 3: hidden xs:block para ocultar el SVG en celulares muy pequeños -->
          <svg
            class="hidden xs:block w-6 h-6 text-white shrink-0 mt-0.5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
            />
          </svg>
          <span class="font-sans font-light text-mont-15 text-white/90">
            {date}
          </span>
        </li>
        <li class="flex items-start gap-3 xs:gap-4">
          <svg
            class="hidden xs:block w-6 h-6 text-white shrink-0 mt-0.5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
            />
          </svg>
          <span class="font-sans font-light text-mont-15 text-white/90">
            {time}
          </span>
        </li>
        <li class="flex items-start gap-3 xs:gap-4">
          <svg
            class="hidden xs:block w-6 h-6 text-white shrink-0 mt-0.5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
              />
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
              />
            </>
          </svg>
          <div class="flex flex-col">
            <span class="font-sans font-medium text-mont-15 text-white">
              {locationName}
            </span>
            {locationAddress && (
              <span class="font-sans font-light text-mont-12 text-white/70 mt-1 uppercase leading-relaxed">
                {locationAddress}
              </span>
            )}
          </div>
        </li>
      </ul>
    )
  }

  {
    dressCodeText && (
      <div class="space-y-6 font-sans font-light text-mont-15 sm:text-mont-18 text-white/90 leading-[1.8] flex-1 mb-10">
        {dressCodeText.map((text) => (
          <p set:html={text} />
        ))}
      </div>
    )
  }

  {
    description && (
      <p class="font-sans font-light text-mont-15 text-white/80 leading-[1.8] flex-1 mb-10">
        {description}
      </p>
    )
  }

  <div class="mt-auto flex flex-wrap gap-4">
    {
      mapLink && (
        <a
          href={mapLink}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block font-sans font-medium text-mont-12 tracking-[0.15em] text-white uppercase underline decoration-white/40 underline-offset-4 transition-colors duration-300 hover:text-gold hover:decoration-gold"
        >
          Ver Ubicación
        </a>
      )
    }

    {
      spotifyLink && (
        <a
          href={spotifyLink}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center gap-2 w-full px-5 py-3 font-sans font-medium text-mont-10 xs:text-mont-12 tracking-[0.15em] text-white uppercase bg-white/10 backdrop-blur-md border border-white/20 rounded-full transition-all duration-300 hover:bg-[#1DB954] hover:border-[#1DB954]"
        >
          <svg class="w-4 h-4 xs:w-5 xs:h-5 shrink-0" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.02.6-1.14 4.32-1.38 9.72-.72 13.44 1.56.418.24.539.84.301 1.26zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.6.18-1.2.72-1.38 4.2-1.26 11.28-1.02 15.721 1.62.539.3.719 1.02.419 1.56-.299.54-1.02.72-1.56.42z"/>
          </svg>
          Spotify
        </a>
      )
    }

    {
      youtubeLink && (
        <a
          href={youtubeLink}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center gap-2 w-full px-5 py-3 font-sans font-medium text-mont-10 xs:text-mont-12 tracking-[0.15em] text-white uppercase bg-white/10 backdrop-blur-md border border-white/20 rounded-full transition-all duration-300 hover:bg-[#FF0000] hover:border-[#FF0000]"
        >
          <svg class="w-4 h-4 xs:w-5 xs:h-5 shrink-0" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
          YouTube
        </a>
      )
    }
  </div>
</div>
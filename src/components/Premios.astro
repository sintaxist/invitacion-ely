---
import SectionTitle from './SectionTitle.astro';
import { Image } from 'astro:assets';

import lightsBg from '../assets/lights-bg.png';
import estatuillaImg from '../assets/estatuilla.png'; 
---

<section class="relative w-full overflow-hidden px-5 xs:px-10 lg:px-25 xl:px-40 mb-25 mx-auto max-w-400 bg-[#050505]">

    <div class="absolute right-0 bottom-0 w-full h-[10%] bg-linear-to-t from-[#050505] via-[#050505]/80 to-transparent pointer-events-none z-10"></div>
    
    <div class="flex flex-col lg:flex-row items-center justify-between gap-12 lg:gap-20 relative z-1">
        
        <div class="w-full lg:w-1/2 flex flex-col mt-10 lg:mt-0 relative z-20">
            
            <SectionTitle 
                subtitle="Ceremonia de Premios" 
                titleWhite="Entrega de" 
                titleGold="Premios" 
            />

            <div class="space-y-6 font-sans font-light text-mont-15 sm:text-mont-18 text-white/90 leading-[1.8]">
                <p>
                    Esta noche no solo celebraremos a la protagonista — también habrá una ceremonia especial de premiación para algunos de los invitados más especiales de la noche.
                </p>
                
                <p class="text-gold tracking-wide font-medium">
                    ¿Serás uno de los galardonados?
                </p>
                
                <p>
                    Prepara tu discurso.
                </p>
            </div>
        </div>

        <div class="w-full lg:w-1/2 relative flex justify-center items-center min-h-112.5 sm:min-h-137.5 lg:min-h-150 mt-5 lg:mt-0">
            
            <div 
              class="absolute inset-0 pointer-events-none z-0 mix-blend-screen opacity-70"
            >
              <Image 
                src={lightsBg} 
                alt="Fondo de luces brillante" 
                class="w-full h-full object-cover object-top"
                loading="lazy"
                decoding="async"
              />
            </div>

            <div class="relative z-10 w-full max-w-50 sm:max-w-75 lg:max-w-65 xl:max-w-70">
               <Image 
                 src={estatuillaImg} 
                 alt="Estatuilla de Premios" 
                 class="w-full h-auto drop-shadow-[0_25px_35px_rgba(0,0,0,0.85)]"
                 loading="lazy"
                 decoding="async"
               /> 
            </div>
            
        </div>
    </div>

</section>
---
import SectionTitle from "./SectionTitle.astro";
import { Image } from "astro:assets";
import ely1 from "../assets/ely-1.jpg";
import ely2 from "../assets/ely-2.jpg";
---

<section
  class="relative w-full max-w-400 overflow-hidden px-5 xs:px-10 lg:px-25 xl:px-40 mb-45 sm:mb-60 mx-auto"
>
  <div
    class="mx-auto flex flex-col lg:flex-row sm:items-center justify-between gap-12 lg:gap-16 xl:gap-20"
  >
    <div class="w-full lg:w-1/2 flex flex-col">
      <SectionTitle subtitle="50 Años" titleWhite="Ely" titleGold="Fraire" />

      <div
        class="space-y-6 font-sans font-light text-mont-15 sm:text-mont-18 text-white/90 leading-[1.8]"
      >
        <p>
          Hay <span class="text-gold">personas que dejan huella</span> para siempre,
          y Ely Fraire es, sin duda, una de ellas.
        </p>

        <p>
          La conocemos en el salón de clases con una paciencia y dedicación que
          pocos tienen, y la conocemos <span class="text-gold"
            >siempre buscando el próximo destino</span
          >, la próxima aventura, el próximo aprendizaje. Y <span
            class="text-gold">su amor por Gloria Trevi</span
          >... absolutamente irrefutable.
        </p>

        <p>
          <span class="text-gold">Ely ha dedicado su vida a lo más hermoso</span
          > que existe: <span class="text-gold"
            >encender la chispa en los ojos de sus alumnos.</span
          > Con 50 años de vida vividos intensamente, su historia merece —y mucho—
          una noche de gala.
        </p>
      </div>
    </div>

    <div class="w-full lg:w-1/2 flex justify-center lg:justify-end">
      <div class="grid grid-cols-2 gap-4 xs:gap-6 w-full max-w-125">
        <Image
          src={ely1}
          alt="Ely Fraire Graduación"
          width={600}
          quality={45}
          loading="lazy"
          decoding="async"
          class="img-scroll-anim opacity-0 w-full h-75 xs:h-100 lg:h-125 object-cover rounded-l-[85px] sm:rounded-l-[150px]"
        />

        <Image
          src={ely2}
          alt="Ely Fraire Viaje"
          width={600}
          quality={45}
          loading="lazy"
          decoding="async"
          class="img-scroll-anim opacity-0 w-full h-75 xs:h-100 lg:h-125 object-cover rounded-br-[85px] sm:rounded-br-[150px]"
        />
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const images = document.querySelectorAll(".img-scroll-anim");

  images.forEach((img, index) => {
    gsap.fromTo(
      img,
      {
        y: 60,
        opacity: 0,
        scale: 0.95,
      },
      {
        scrollTrigger: {
          trigger: img,
          start: "top 50%",
          toggleActions: "play none none none",
        },
        y: 0,
        opacity: 1,
        scale: 1,
        duration: 1.4,
        delay: index * 0.2,
        ease: "power3.out",
        onStart: () => {
          img.classList.remove("opacity-0");
        },
        clearProps: "transform",
      },
    );
  });
</script>

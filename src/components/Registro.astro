---
import SectionTitle from "./SectionTitle.astro";
import WhatsAppCard from "./WhatsAppCard.astro";
---

<section
  class="relative w-full max-w-400 px-5 xs:px-10 lg:px-25 xl:px-40 mb-50 mx-auto"
  id="registro"
>
  <div
    class="mx-auto flex flex-col lg:flex-row sm:items-center justify-between gap-12 lg:gap-16 xl:gap-20"
  >
    <div class="w-full lg:w-1/2 flex flex-col">
      <SectionTitle
        subtitle="confirmación de asistencia"
        titleWhite="la ceremonia"
        titleGold="te espera"
      />

      <p
        class="font-sans font-light text-mont-15 sm:text-mont-18 text-white/90 leading-[1.8] mb-10"
      >
        Confirma tu asistencia antes del <span class="text-gold"
          >27 de Noviembre</span
        > para reservar tu lugar en esta noche histórica.
      </p>

      <p
        class="font-sans text-mont-15 text-white/70 uppercase tracking-widest mb-4 text-left"
      >
        Faltan exactamente:
      </p>
      <hr class="w-full border-white opacity-60 mb-6" />

      <div
        id="timer"
        class="font-serif text-rose-25 text-center xs:text-rose-30 lg:text-rose-40 text-white tracking-widest leading-none"
      >
        00d : 00h : 00m : 00s
      </div>

      <hr class="w-full border-white opacity-60 mt-6" />
    </div>

    <div class="w-full lg:w-1/2 flex justify-center lg:justify-end">
      <WhatsAppCard
        phoneNumber="525521325532"
        message="¡Hola! Ely. Confirmo con muchísimo gusto mi asistencia para celebrar tus 50 años. ¡Ahí estaré para festejar!"
      />
    </div>
  </div>
</section>

<script>
  function updateTimer() {
    const targetDate = new Date("December 5, 2026 00:00:00").getTime();
    const now = new Date().getTime();
    const diff = targetDate - now;

    if (diff <= 0) {
      const timerEl = document.getElementById("timer");
      if (timerEl) timerEl.innerText = "¡El día ha llegado!";
      return;
    }

    const d = Math.floor(diff / (1000 * 60 * 60 * 24))
      .toString()
      .padStart(2, "0");
    const h = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60))
      .toString()
      .padStart(2, "0");
    const m = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60))
      .toString()
      .padStart(2, "0");
    const s = Math.floor((diff % (1000 * 60)) / 1000)
      .toString()
      .padStart(2, "0");

    const timerEl = document.getElementById("timer");
    if (timerEl) {
      timerEl.innerText = `${d}d : ${h}h : ${m}m : ${s}s`;
    }
  }

  setInterval(updateTimer, 1000);
  updateTimer();
</script>

---

---

<div
  id="loader-screen"
  class="fixed inset-0 z-50 flex flex-col bg-black items-center justify-center transition-opacity duration-500"
>
  <div class="loader-logo flex space-x-6 mb-6">
    <span class="loader-text">E</span>
    <span class="loader-text">L</span>
    <span class="loader-text">Y</span>
  </div>
  <div class="w-48 h-px bg-gray-800 relative overflow-hidden">
    <div
      id="loader-bar"
      class="absolute top-0 left-0 h-full bg-gold w-0 transition-all duration-300 ease-out"
    >
    </div>
  </div>
  <div
    id="loader-percentage"
    class="text-gold text-xs mt-4 font-light tracking-[0.2em] font-sans"
  >
    0%
  </div>
</div>

<div
  id="canvas-container"
  class="absolute lg:relative z-10 max-w-150 w-full lg:w-1/2 h-screen min-h-187.5 lg:min-h-200 max-h-225 flex justify-center items-center inset-0 lg:inset-auto mx-auto lg:mx-0"
>
</div>

<style>
  .loader-text {
    font-family: "Rosehot", serif;
    font-size: 3.5rem;
    color: var(--color-gold, #c99040);
    opacity: 0;
    transform: translateY(15px);
    animation: elegantFadeUp 0.5s ease-out forwards;
  }
  .loader-text:nth-child(1) {
    animation-delay: 0.1s;
  }
  .loader-text:nth-child(2) {
    animation-delay: 0.3s;
  }
  .loader-text:nth-child(3) {
    animation-delay: 0.5s;
  }

  @keyframes elegantFadeUp {
    from {
      opacity: 0;
      transform: translateY(15px);
      filter: blur(2px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }
  }
</style>

<script>
  const container = document.getElementById("canvas-container");
  initThreeScene();

  async function initThreeScene() {
    const THREE = await import("three");
    const { GLTFLoader } = await import("three/examples/jsm/loaders/GLTFLoader.js");
    const { DRACOLoader } = await import("three/examples/jsm/loaders/DRACOLoader.js");
    const { OrbitControls } = await import("three/examples/jsm/controls/OrbitControls.js");
    const { RoomEnvironment } = await import("three/examples/jsm/environments/RoomEnvironment.js");
    const { EffectComposer } = await import("three/examples/jsm/postprocessing/EffectComposer.js");
    const { RenderPass } = await import("three/examples/jsm/postprocessing/RenderPass.js");
    const { UnrealBloomPass } = await import("three/examples/jsm/postprocessing/UnrealBloomPass.js");
    const { OutputPass } = await import("three/examples/jsm/postprocessing/OutputPass.js");
    const { gsap } = await import("gsap");
    const { MATERIALS, DRACO_PATH, MODEL_PATH } = await import("../utils/varThreeJs");

    const isScrolledDown = window.scrollY > window.innerHeight * 0.2;

    if (isScrolledDown) {
      gsap.to("#loader-screen", {
        opacity: 0,
        duration: 0.3,
        onComplete: () => {
          const loader = document.getElementById("loader-screen");
          if (loader) loader.style.display = "none";
          (window as any).scene3DReady = true;
          window.dispatchEvent(new Event("scene3d-loaded"));
        }
      });
    }

    const MOBILE_BREAKPOINT = 1000;
    const MOUSE_BREAKPOINT = 968;
    let isResetting = false; 

    function isMobile() {
      return window.innerWidth <= MOBILE_BREAKPOINT;
    }

    function isHighEndMobile() {
      const cores = navigator.hardwareConcurrency || 2;
      const memory = (navigator as any).deviceMemory || 4; 
      const dpr = window.devicePixelRatio || 1;
      return cores >= 6 && (memory >= 6 || dpr >= 2.5);
    }

    const canInteract = !isMobile() || isHighEndMobile();
    const PARTICLE_COUNT = isMobile() ? 60 : 75; 

    function createParticleTexture() {
      const canvas = Object.assign(document.createElement("canvas"), { width: 32, height: 32 });
      const ctx = canvas.getContext("2d")!;
      const gradient = ctx.createRadialGradient(16, 16, 0, 16, 16, 16);
      gradient.addColorStop(0, "rgba(255,255,255,1)");
      gradient.addColorStop(1, "rgba(255,255,255,0)");
      ctx.fillStyle = gradient;
      ctx.fillRect(0, 0, 32, 32);
      return new THREE.CanvasTexture(canvas);
    }

    function buildParticles(maxDim: any) {
      const geometry = new THREE.BufferGeometry();
      const positions = new Float32Array(PARTICLE_COUNT * 3);
      const speeds = new Float32Array(PARTICLE_COUNT);
      const sways = new Float32Array(PARTICLE_COUNT);

      const spreadY = isMobile() ? 3 : 5;
      const spreadR = isMobile() ? 0.35 : 0.6; 

      for (let i = 0; i < PARTICLE_COUNT; i++) {
        const y = -maxDim + Math.random() * (maxDim * spreadY);
        const r = Math.sqrt(Math.random()) * maxDim * spreadR;
        const theta = Math.random() * Math.PI * 2;
        positions[i * 3] = r * Math.cos(theta);
        positions[i * 3 + 1] = y;
        positions[i * 3 + 2] = r * Math.sin(theta);
        
        speeds[i] = (Math.random() * 0.0015 + 0.0005) * maxDim;
        sways[i] = Math.random() * Math.PI * 2;
      }

      geometry.setAttribute("position", new THREE.BufferAttribute(positions, 3));
      const material = new THREE.PointsMaterial({
        color: 0xffeebb, size: maxDim * 0.015, transparent: true, opacity: 1,
        blending: THREE.AdditiveBlending, depthWrite: false, map: createParticleTexture(),
      });

      const points: any = new THREE.Points(geometry, material);
      points.speeds = speeds; points.sways = sways;
      return points;
    }

    function setupRenderer(container: any) {
      const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: !isMobile() });
      renderer.setSize(container.clientWidth, container.clientHeight);
      renderer.setPixelRatio(isMobile() ? 1 : Math.min(window.devicePixelRatio, 2));
      renderer.toneMapping = THREE.ACESFilmicToneMapping;
      renderer.toneMappingExposure = 1.0;
      container.appendChild(renderer.domElement);
      return renderer;
    }

    function setupComposer(renderer: any, scene: any, camera: any) {
      const composer = new EffectComposer(renderer);
      composer.addPass(new RenderPass(scene, camera));
      const bloom = new UnrealBloomPass(new THREE.Vector2(window.innerWidth, window.innerHeight), 1.5, 0.4, 0.85);
      bloom.threshold = 0.95; bloom.strength = 0.25; bloom.radius = 0.3;
      composer.addPass(bloom);
      composer.addPass(new OutputPass());
      return composer;
    }

    function setupControls(camera: any, domElement: any) {
      const controls = new OrbitControls(camera, domElement);
      controls.enableDamping = true; controls.dampingFactor = 0.04;
      controls.enableZoom = false; controls.enablePan = false;
      controls.minPolarAngle = Math.PI / 3; controls.maxPolarAngle = Math.PI / 2 + 0.05;
      controls.autoRotate = false;
      controls.enabled = canInteract;
      return controls;
    }

    function setupLights(scene: any, maxDim: any) {
      scene.add(new THREE.AmbientLight(0xffffff, 0.3));
      const dirLight = new THREE.DirectionalLight(0xffffff, 1);
      dirLight.position.set(3, 3, 5);
      scene.add(dirLight);
      const spotLight = new THREE.SpotLight(0xffeedd, 30);
      spotLight.position.set(0, maxDim * 2.5, 0);
      spotLight.angle = Math.PI / 8; spotLight.penumbra = 0.8;
      scene.add(spotLight); scene.add(spotLight.target);
    }

    function hideLoader() {
      const loader = document.getElementById("loader-screen");
      
      if (isScrolledDown) {
        return gsap.to({}, { duration: 0 });
      }
      
      return gsap.to("#loader-screen", {
        opacity: 0, duration: 0.6, ease: "power2.inOut",
        onComplete: () => {
          if (loader) loader.style.display = "none";
          (window as any).scene3DReady = true;
          window.dispatchEvent(new Event("scene3d-loaded"));
        },
      });
    }

    function playIntroAnimation(modelGroup: any, interactionWrapper: any, targetScale: any, finalHeightOffset: any, tiltZ: any, tiltX: any) {
      gsap.timeline().add(hideLoader())
        .to(modelGroup.scale, { x: targetScale, y: targetScale, z: targetScale, duration: 1.2, ease: "power2.out" }, "-=0.2")
        .to(modelGroup.position, { y: finalHeightOffset, duration: 1.0, ease: "power2.out" }, "<")
        .to(interactionWrapper.rotation, { z: tiltZ, x: tiltX, duration: 1.0, ease: "power2.out" }, "<")
        .fromTo(modelGroup.rotation, { y: -Math.PI / 4 }, { y: 0, duration: 1.2, ease: "power2.out" }, "<");
    }

    function setupResetOnIdle(controls: any, camera: any, originalCameraZ: any, modelGroup: any) {
      if (!canInteract) return;
      let resetTimeout: ReturnType<typeof setTimeout> | undefined;

      controls.addEventListener("start", () => {
        if (resetTimeout) clearTimeout(resetTimeout);
        if (camera.userData.tween) camera.userData.tween.kill();
        isResetting = false;
      });

      controls.addEventListener("end", () => {
        resetTimeout = setTimeout(() => {
          controls.enabled = false;
          isResetting = true;

          const startSpherical = new THREE.Spherical().setFromVector3(camera.position);
          let targetTheta = 0;
          let thetaDiff = targetTheta - startSpherical.theta;
          thetaDiff = Math.atan2(Math.sin(thetaDiff), Math.cos(thetaDiff));
          targetTheta = startSpherical.theta + thetaDiff;

          const targetModelY = Math.round(modelGroup.rotation.y / (Math.PI * 2)) * (Math.PI * 2);

          const proxy = { 
            t: 0,
            modelY: modelGroup.rotation.y,
            camRadius: startSpherical.radius,
            camPhi: startSpherical.phi,
            camTheta: startSpherical.theta
          };

          camera.userData.tween = gsap.to(proxy, {
            t: 1,
            modelY: targetModelY,
            camRadius: originalCameraZ,
            camPhi: Math.PI / 2,
            camTheta: targetTheta,
            duration: 1.2,
            ease: "power2.inOut",
            onUpdate: () => {
              modelGroup.rotation.y = proxy.modelY;
              camera.position.setFromSphericalCoords(proxy.camRadius, proxy.camPhi, proxy.camTheta);
              camera.lookAt(0, 0, 0);
            },
            onComplete: () => {
              controls.enableDamping = false;
              controls.update(); 
              
              camera.position.set(0, 0, originalCameraZ);
              camera.lookAt(0, 0, 0);
              modelGroup.rotation.y = targetModelY;
              
              controls.target.set(0, 0, 0);
              controls.update(); 
              
              controls.enableDamping = true;
              controls.enabled = canInteract;
              isResetting = false;
            }
          });
        }, 600); 
      });
    }

    let mouseX = 0, mouseY = 0;
    function onMouseMove({ clientX, clientY }: any) {
      if (window.innerWidth > MOUSE_BREAKPOINT) {
        mouseX = (clientX - window.innerWidth / 2) * 0.001;
        mouseY = (clientY - window.innerHeight / 2) * 0.001;
      }
    }
    document.addEventListener("mousemove", onMouseMove);

    if (!container) throw new Error("canvas-container not found");
    container.replaceChildren();

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(45, container.clientWidth / container.clientHeight, 0.1, 1000);
    const renderer = setupRenderer(container);
    const composer = setupComposer(renderer, scene, camera);
    const controls = setupControls(camera, renderer.domElement);

    const pmrem = new THREE.PMREMGenerator(renderer);
    scene.environment = pmrem.fromScene(new RoomEnvironment(), 0.04).texture;
    
    const modelGroup = new THREE.Group();
    const interactionWrapper = new THREE.Group();
    interactionWrapper.add(modelGroup);
    scene.add(interactionWrapper);
    modelGroup.scale.setScalar(0);
    
    let maxDim = 0;
    let particles: any = null;

    const dracoLoader = new DRACOLoader();
    dracoLoader.setDecoderPath(DRACO_PATH);
    dracoLoader.preload();

    const gltfLoader = new GLTFLoader();
    gltfLoader.setDRACOLoader(dracoLoader);

    const bar = document.getElementById("loader-bar");
    const txt = document.getElementById("loader-percentage");
    let fakePct = { val: 0 };
    const pctTween = gsap.to(fakePct, {
      val: 90, duration: 4, ease: "power1.out",
      onUpdate: () => {
        if (bar) bar.style.width = `${fakePct.val}%`;
        if (txt) txt.innerText = `${Math.floor(fakePct.val)}%`;
      }
    });

    gltfLoader.load(
      MODEL_PATH,
      (gltf: any) => {
        pctTween.kill();
        if (bar) bar.style.width = `100%`;
        if (txt) txt.innerText = `100%`;

        const model = gltf.scene;
        model.traverse((child: any) => {
          if (!child.isMesh) return;
          child.material = child.name.toLowerCase().includes("object_3") ? MATERIALS.base : MATERIALS.gold;
          child.castShadow = true; child.receiveShadow = true;
        });

        const box = new THREE.Box3().setFromObject(model);
        const size = box.getSize(new THREE.Vector3());
        const center = box.getCenter(new THREE.Vector3());
        model.position.sub(center);
        modelGroup.add(model);

        maxDim = Math.max(size.x, size.y, size.z);
        setupLights(scene, maxDim);

        const fov = camera.fov * (Math.PI / 180);
        const originalCameraZ = Math.abs(maxDim / 2 / Math.tan(fov / 2)) * (isMobile() ? 2 : 1.3);
        camera.position.set(0, 0, originalCameraZ);
        controls.target.set(0, 0, 0);
        camera.updateProjectionMatrix();

        const targetScale = isMobile() ? 1.5 : 0.95;
        const finalHeightOffset = isMobile() ? maxDim * 0.08 : -(maxDim * 0.01);
        
        const tiltX = isMobile() ? 0 : 0.10; 
        const tiltZ = isMobile() ? 0 : -0.15;

        modelGroup.position.y = finalHeightOffset - maxDim * 0.3;

        particles = buildParticles(maxDim);
        scene.add(particles);

        playIntroAnimation(modelGroup, interactionWrapper, targetScale, finalHeightOffset, tiltZ, tiltX);
        setupResetOnIdle(controls, camera, originalCameraZ, modelGroup);
      },
      undefined,
      (error: any) => {
        console.error("Error loading model:", error);
        hideLoader();
      },
    );

    function animateParticles(timeScale: any) {
      if (!particles || maxDim === 0) return;
      const pos = particles.geometry.attributes.position.array;
      const speeds = particles.speeds;
      const sways = particles.sways;
      const desktop = window.innerWidth > MOUSE_BREAKPOINT;

      for (let i = 0; i < PARTICLE_COUNT; i++) {
        pos[i * 3 + 1] -= speeds[i] * timeScale;
        pos[i * 3] += Math.sin(sways[i]) * 0.0005 * maxDim;
        sways[i] += 0.006 * timeScale;
        
        if (pos[i * 3 + 1] < -maxDim) pos[i * 3 + 1] = maxDim * 4;
      }
      particles.geometry.attributes.position.needsUpdate = true;

      if (desktop) {
        particles.rotation.y += 0.05 * (mouseX * 1.5 - particles.rotation.y);
        particles.rotation.x += 0.05 * (mouseY * 1.5 - particles.rotation.x);
      }
    }

    let rafId = 0;
    let isSceneVisible = true;
    
    const TARGET_FPS = canInteract ? 60 : 30;
    const FRAME_INTERVAL = 1000 / TARGET_FPS;
    let lastFrameTime = performance.now();

    const visibilityObserver = new IntersectionObserver((entries) => {
      isSceneVisible = entries[0].isIntersecting;
    }, { threshold: 0 });
    visibilityObserver.observe(container);

    function animate(currentTime: any = performance.now()) {
      rafId = requestAnimationFrame(animate);
      if (!isSceneVisible) return;
      
      const delta = currentTime - lastFrameTime;
      
      if (delta >= FRAME_INTERVAL) {
        const timeScale = delta / (1000 / 60);
        lastFrameTime = currentTime - (delta % FRAME_INTERVAL);
        
        animateParticles(timeScale);
        
        if (!isResetting) {
          modelGroup.rotation.y -= 0.012 * timeScale; 
        }
        
        if(controls.enabled) controls.update();
        composer.render();
      }
    }
    animate();

    function onResize() {
      camera.aspect = container!.clientWidth / container!.clientHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(container!.clientWidth, container!.clientHeight);
      composer.setSize(container!.clientWidth, container!.clientHeight);

      if (interactionWrapper) {
        if (window.innerWidth <= MOUSE_BREAKPOINT) {
          interactionWrapper.rotation.set(0, 0, 0);
        } else {
          interactionWrapper.rotation.set(0.10, 0, -0.15);
        }
      }
    }
    window.addEventListener("resize", onResize);

    function cleanup() {
      cancelAnimationFrame(rafId);
      window.removeEventListener("resize", onResize);
      visibilityObserver.disconnect();
      gsap.killTweensOf("#loader-screen");
      pctTween.kill();
      if(camera.userData.tween) camera.userData.tween.kill();

      controls.dispose();
      particles?.geometry.dispose();
      particles?.material?.dispose();
      pmrem.dispose();
      if (composer.dispose) composer.dispose();

      renderer.dispose();
      if (renderer.forceContextLoss) renderer.forceContextLoss();
      renderer.domElement.remove();
    }

    document.addEventListener("astro:before-swap", cleanup, { once: true });
    // @ts-ignore
    if (import.meta.hot) { import.meta.hot.dispose(cleanup); }
  }
</script>
